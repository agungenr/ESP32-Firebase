#define ENABLE_USER_AUTH
#define ENABLE_DATABASE

#include <Arduino.h>
#include <WiFi.h>
#include <WiFiClientSecure.h>
#include <FirebaseClient.h>
#include <DHT.h>
#include <time.h>

// WiFi
#define WIFI_SSID "CR55"
#define WIFI_PASSWORD "xxxxx"

// Firebase
#define Web_API_KEY "AIzaSy***"
#define DATABASE_URL "https://iot-itts-dht22-default-rtdb.asia-southeast1.firebasedatabase.app/"

// Firebase Authentication
// Untuk contoh ini pakai Email/Password.
// Nanti buat user di Firebase Authentication jika belum ada.
#define USER_EMAIL "device1@itts.local"
#define USER_PASS "password123"

// DHT22
#define DHTPIN 18
#define DHTTYPE DHT22
DHT dht(DHTPIN, DHTTYPE);

// Firebase objects
UserAuth user_auth(Web_API_KEY, USER_EMAIL, USER_PASS);
FirebaseApp app;
WiFiClientSecure ssl_client;
using AsyncClient = AsyncClientClass;
AsyncClient aClient(ssl_client);
RealtimeDatabase Database;

unsigned long lastSendTime = 0;
const unsigned long sendInterval = 5000;

void processData(AsyncResult &aResult) {
  if (!aResult.isResult()) return;

  if (aResult.isEvent()) {
    Firebase.printf("Event task: %s, msg: %s, code: %d\n",
                    aResult.uid().c_str(),
                    aResult.eventLog().message().c_str(),
                    aResult.eventLog().code());
  }

  if (aResult.isDebug()) {
    Firebase.printf("Debug task: %s, msg: %s\n",
                    aResult.uid().c_str(),
                    aResult.debug().c_str());
  }

  if (aResult.isError()) {
    Firebase.printf("Error task: %s, msg: %s, code: %d\n",
                    aResult.uid().c_str(),
                    aResult.error().message().c_str(),
                    aResult.error().code());
  }

  if (aResult.available()) {
    Firebase.printf("task: %s, payload: %s\n",
                    aResult.uid().c_str(),
                    aResult.c_str());
  }
}

void connectWiFi() {
  Serial.print("Connecting to WiFi: ");
  Serial.println(WIFI_SSID);

  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println();
  Serial.println("WiFi Connected!");
  Serial.print("IP Address: ");
  Serial.println(WiFi.localIP());
}

void setup() {
  Serial.begin(115200);
  delay(1000);

  dht.begin();
  connectWiFi();

  configTime(7 * 3600, 0, "pool.ntp.org");
  Serial.println("Sync NTP...");
  struct tm timeinfo;

  while (!getLocalTime(&timeinfo)) {
    Serial.print(".");
    delay(1000);
  }
  Serial.println("\nNTP Time Ready");

  ssl_client.setInsecure();

  initializeApp(aClient, app, getAuth(user_auth), processData, "authTask");

  app.getApp<RealtimeDatabase>(Database);
  Database.url(DATABASE_URL);
}

void loop() {

  app.loop();

  if (app.ready()) {

    unsigned long currentTime = millis();

    if (currentTime - lastSendTime >= sendInterval) {

      lastSendTime = currentTime;

      float humidity = dht.readHumidity();
      float temperature = dht.readTemperature();

      if (isnan(humidity) || isnan(temperature)) {
        Serial.println("DHT22 read failed");
        return;
      }

      Serial.print("Temperature: ");
      Serial.print(temperature);
      Serial.print(" C | Humidity: ");
      Serial.print(humidity);
      Serial.println(" %");

      // Update latest value
      Database.set<float>(aClient,
                          "/dht22/temperature",
                          temperature,
                          processData,
                          "RTDB_Latest_Temperature");

      Database.set<float>(aClient,
                          "/dht22/humidity",
                          humidity,
                          processData,
                          "RTDB_Latest_Humidity");

      // Generate timestamp dari NTP
      struct tm timeinfo;

      if (getLocalTime(&timeinfo)) {

        char timestamp[30];

        strftime(timestamp,
                 sizeof(timestamp),
                 "%Y-%m-%d_%H-%M-%S",
                 &timeinfo);

        String logPath =
          "/dht22_logs/" + String(timestamp);

        // Simpan historical log
        Database.set<float>(aClient,
                            logPath + "/temperature",
                            temperature,
                            processData,
                            "RTDB_Log_Temperature");

        Database.set<float>(aClient,
                            logPath + "/humidity",
                            humidity,
                            processData,
                            "RTDB_Log_Humidity");

        Serial.print("Saved log to: ");
        Serial.println(logPath);
      }
      else {
        Serial.println("Failed to get NTP time");
      }
    }
  }
}
